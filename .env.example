# =========================
# Database
# =========================
DATABASE_URL=postgres://scanlark_user:YOURPASS@localhost:5432/scanlark_dev

# =========================
# App URLs (used for links in emails)
# =========================
# Public base URL of the web dashboard (used in email "View in dashboard" links)
APP_URL=http://localhost:5173

# =========================
# Auth (beta gate)
# =========================
# DEV_BYPASS_AUTH=true
DEMO_USER_EMAIL=demo@scanlark.local
AUTH_COOKIE_NAME=ls_session
SESSION_SECRET=change-me-32+chars
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:3001
API_INTERNAL_TOKEN=change-me-internal-token
API_JSON_LIMIT=256kb
API_WRITE_RATE_LIMIT_PER_MINUTE=120
PUBLIC_REPORT_RATE_LIMIT_PER_MINUTE=120
SCAN_ACTION_RATE_LIMIT_PER_10_MINUTES=20
LINK_RECHECK_RATE_LIMIT_PER_10_MINUTES=30
TEST_EMAIL_RATE_LIMIT_PER_10_MINUTES=5
SHARE_ACTION_RATE_LIMIT_PER_10_MINUTES=20
IGNORE_RULE_RATE_LIMIT_PER_10_MINUTES=30
# Comma-separated internal admin allowlist. Leave empty to disable admin access.
# Example: ADMIN_EMAILS=owner@example.com,ops@example.com
ADMIN_EMAILS=

# Public report share token signing.
# Required outside development/test so existing share links remain stable.
REPORT_SHARE_TOKEN_SECRET=change-me-report-share-token-secret

# Worker settings
WORKER_API_BASE=http://localhost:3001
UPTIME_TICK_MS=60000
UPTIME_BATCH_SIZE=25

# =========================
# Email (SMTP) — MVP notifications
# =========================
# If false/0/empty, the app will NOT send emails (it will log what it would send)
EMAIL_ENABLED=true

# Who the emails appear to come from
EMAIL_FROM="Scanlark <alerts@scanlark.local>"

# SMTP server settings (Mailpit defaults)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Optional override for the "Send test email" endpoint (useful in dev)
# If set, test emails go here instead of the site's notify_email
EMAIL_TEST_TO=
