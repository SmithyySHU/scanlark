# Copy to .env.production on the VPS and replace every CHANGE_ME value.
# Do not commit .env.production.

# Domain / TLS
SCANLARK_DOMAIN=scanlark.example.com
CADDY_ACME_EMAIL=admin@scanlark.example.com

# Postgres
POSTGRES_DB=scanlark
POSTGRES_USER=scanlark
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
DATABASE_URL=postgres://scanlark:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/scanlark

# Runtime
NODE_ENV=production
DEV_BYPASS_AUTH=false
AUTH_COOKIE_NAME=ls_session
SESSION_SECRET=CHANGE_ME_32_PLUS_CHARACTER_RANDOM_SECRET
REPORT_SHARE_TOKEN_SECRET=CHANGE_ME_32_PLUS_CHARACTER_RANDOM_SHARE_SECRET
API_INTERNAL_TOKEN=CHANGE_ME_32_PLUS_CHARACTER_RANDOM_INTERNAL_TOKEN
API_JSON_LIMIT=256kb
API_WRITE_RATE_LIMIT_PER_MINUTE=120
PUBLIC_REPORT_RATE_LIMIT_PER_MINUTE=120
SCAN_ACTION_RATE_LIMIT_PER_10_MINUTES=20
LINK_RECHECK_RATE_LIMIT_PER_10_MINUTES=30
TEST_EMAIL_RATE_LIMIT_PER_10_MINUTES=5
SHARE_ACTION_RATE_LIMIT_PER_10_MINUTES=20
IGNORE_RULE_RATE_LIMIT_PER_10_MINUTES=30
# Comma-separated internal admin allowlist. Leave empty to disable admin access.
ADMIN_EMAILS=admin@example.com

# Public URLs
APP_URL=https://scanlark.example.com
WEB_ORIGIN=https://scanlark.example.com
API_ORIGIN=https://scanlark.example.com/api
VITE_API_BASE=/api

# Worker
WORKER_API_BASE=http://api:3001
UPTIME_TICK_MS=60000
UPTIME_BATCH_SIZE=25

# Email / SMTP
EMAIL_ENABLED=true
EMAIL_FROM="Scanlark <alerts@scanlark.example.com>"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
EMAIL_TEST_TO=
